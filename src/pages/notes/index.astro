---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { noteThumb, readingTime, TOPICS } from '../../lib/notes';

const notes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });
---

<Layout title="Notes · Gaby Charalampidi" current="notes">
  <section class="hero">
    <h1>Notes</h1>
  </section>

  <div class="topic-filter" role="group" aria-label="Filter notes by topic">
    <button class="active" data-topic="">All</button>
    {TOPICS.map((t) => <button data-topic={t}>{t}</button>)}
  </div>

  <ul class="note-list">
    {
      notes.map((note) => {
        const thumb = noteThumb(note.data);
        const mins = note.data.type === 'article' ? readingTime(note.body) : 0;
        return (
          <li data-topic={note.data.topic ?? ''}>
            <a class="note-card" href={`/notes/${note.id}`}>
              <div class="note-text">
                <span class="note-meta">
                  {note.data.topic && <span class="topic-chip">{note.data.topic}</span>}
                  <time datetime={note.data.date.toISOString()}>{fmt(note.data.date)}</time>
                  {note.data.type === 'video' && <span class="tag">Video</span>}
                  {mins > 0 && <span>{mins} min read</span>}
                </span>
                <h2>{note.data.title}</h2>
                {note.data.description && <p class="desc">{note.data.description}</p>}
              </div>
              {thumb && (
                <div class="note-thumb">
                  <img src={thumb} alt="" loading="lazy" />
                  {note.data.type === 'video' && (
                    <span class="play" aria-hidden="true">
                      <svg viewBox="0 0 24 24" fill="currentColor">
                        <path d="M8 5.5v13l11-6.5z" />
                      </svg>
                    </span>
                  )}
                </div>
              )}
            </a>
          </li>
        );
      })
    }
  </ul>

  <p class="muted empty-topic" hidden>Nothing under this topic yet.</p>
  {notes.length === 0 && <p class="muted">Nothing here yet. First note coming soon.</p>}
</Layout>

<script>
  const buttons = [...document.querySelectorAll<HTMLButtonElement>('.topic-filter button')];
  const items = [...document.querySelectorAll<HTMLLIElement>('.note-list li')];
  const empty = document.querySelector<HTMLElement>('.empty-topic')!;
  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      buttons.forEach((b) => b.classList.toggle('active', b === btn));
      const topic = btn.dataset.topic || '';
      let shown = 0;
      items.forEach((li) => {
        const show = !topic || li.dataset.topic === topic;
        li.hidden = !show;
        if (show) shown++;
      });
      empty.hidden = shown > 0;
    });
  });
</script>

<style>
  .hero {
    margin-top: 3.5rem;
  }

  .hero h1 {
    font-size: clamp(2rem, 5vw, 2.6rem);
  }

  .lede {
    margin-top: 1rem;
    color: var(--muted);
    max-width: 34rem;
  }

  .topic-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 2.2rem;
  }

  .topic-filter button {
    padding: 0.35rem 1rem;
    background: transparent;
    border: 1px solid var(--line);
    border-radius: 999px;
    color: var(--muted);
    font-family: var(--sans);
    font-size: 0.85rem;
    cursor: pointer;
    transition: color 120ms ease, border-color 120ms ease;
  }

  .topic-filter button:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .topic-filter button.active {
    color: var(--bg);
    background: var(--accent);
    border-color: var(--accent);
  }

  .note-list {
    list-style: none;
    padding: 0;
    margin: 2rem 0 0;
  }

  .note-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.6rem;
    padding: 1.1rem 0;
    text-decoration: none;
  }

  .note-card:hover {
    color: inherit;
  }

  .note-card:hover h2 {
    color: var(--accent);
  }

  .note-text {
    min-width: 0;
  }

  .note-text h2 {
    font-size: 1.35rem;
    margin: 0.45rem 0 0;
    transition: color 120ms ease;
  }

  .desc {
    margin: 0.5rem 0 0;
    color: var(--muted);
    font-size: 0.95rem;
    max-width: 32rem;
  }

  .note-meta {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    font-size: 0.8rem;
    color: var(--faint);
  }

  .tag {
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.08rem 0.5rem;
  }

  .note-thumb {
    position: relative;
    flex: 0 0 176px;
    aspect-ratio: 16 / 9;
    border-radius: 6px;
    overflow: hidden;
    border: 1px solid var(--line);
    background: #21242c;
  }

  .note-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--ink);
    background: rgba(23, 25, 30, 0.35);
  }

  .play svg {
    width: 34px;
    height: 34px;
    filter: drop-shadow(0 1px 4px rgba(0, 0, 0, 0.5));
  }

  @media (max-width: 560px) {
    .note-card {
      flex-direction: column-reverse;
      align-items: stretch;
      gap: 0.9rem;
    }

    .note-thumb {
      flex: none;
      width: 100%;
    }
  }
</style>
