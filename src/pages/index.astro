---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const notes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const latest = notes.slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });

const projects = [
  {
    name: 'Escalation engine',
    stack: 'Apps Script',
    what: 'The attendance policy, running as code.',
  },
  {
    name: 'Inventory system',
    stack: 'Express · LibSQL',
    what: 'Stock, transfers, and alerts across three sites.',
  },
  {
    name: 'Compliance tracker',
    stack: 'Sheets · Apps Script',
    what: '50 staff certifications, zero manual entry.',
  },
  {
    name: 'Club extensions',
    stack: 'Chrome',
    what: 'Payroll recalculation and live coach notes.',
  },
  {
    name: 'rippnertennis.com',
    stack: 'Next.js · Cloudflare',
    what: 'The marketing site, rebuilt from WordPress.',
  },
  {
    name: 'Tools portal',
    stack: 'Cloudflare Pages',
    what: 'Schedulers and dashboards, one home.',
  },
];
---

<Layout title="Gaby Charalampidi" current="home">
  <section class="hero">
    <!-- To scale: 78x36 ft doubles court at 3.2 px/ft, net posts 3 ft outside the sidelines -->
    <svg class="court" viewBox="0 0 160 270" aria-hidden="true" fill="none">
      <rect x="22.4" y="10" width="115.2" height="249.6" stroke="currentColor" />
      <line x1="36.8" y1="10" x2="36.8" y2="259.6" stroke="currentColor" />
      <line x1="123.2" y1="10" x2="123.2" y2="259.6" stroke="currentColor" />
      <line x1="36.8" y1="67.6" x2="123.2" y2="67.6" stroke="currentColor" />
      <line x1="36.8" y1="202" x2="123.2" y2="202" stroke="currentColor" />
      <line x1="80" y1="67.6" x2="80" y2="202" stroke="currentColor" />
      <line x1="80" y1="10" x2="80" y2="16" stroke="currentColor" />
      <line x1="80" y1="259.6" x2="80" y2="253.6" stroke="currentColor" />
      <line x1="12.8" y1="134.8" x2="147.2" y2="134.8" stroke="currentColor" stroke-width="2" />
    </svg>
    <p class="eyebrow">Austin, TX</p>
    <h1>
      I <em>run</em> tennis facilities and <em>build</em> the software behind them.
    </h1>
    <p class="lede">
      COO at <a href="https://rippnertennis.com">Rippner Tennis</a>. When the operation needs a
      tool that does not exist, I build it myself.
    </p>
  </section>

  {
    latest.length > 0 && (
      <section class="section" id="notes">
        <h2 class="label">Latest notes</h2>
        <ul class="note-list">
          {latest.map((note) => (
            <li>
              <a href={`/notes/${note.id}`}>{note.data.title}</a>
              <span class="note-meta">
                {note.data.topic && <span class="topic-chip">{note.data.topic}</span>}
                {note.data.type === 'video' && <span class="tag">Video</span>}
                <time datetime={note.data.date.toISOString()}>{fmt(note.data.date)}</time>
              </span>
            </li>
          ))}
        </ul>
        <p class="all-notes">
          <a href="/notes">All notes &rarr;</a>
        </p>
      </section>
    )
  }

  <section class="section" id="work">
    <h2 class="label">Things I've built</h2>
    <p class="kicker">
      Every tool here exists because something broke, cost hours, or lived in one person's head.
    </p>
    <ol class="projects">
      {
        projects.map((p, i) => (
          <li>
            <span class="num">{String(i + 1).padStart(2, '0')}</span>
            <h3>{p.name}</h3>
            <p>{p.what}</p>
            <span class="stack">{p.stack}</span>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="section" id="path">
    <h2 class="label">The path</h2>
    <ol class="timeline">
      <li>
        <p class="tl-era">Greece</p>
        <h3>Competitive tennis</h3>
        <p>ITF juniors, a world ranking of 245, and the Greek National Team.</p>
      </li>
      <li>
        <p class="tl-era">Reno, NV</p>
        <h3>Engineering</h3>
        <p>
          Division I tennis at Nevada on a full athletic scholarship, with a B.S. in Computer
          Science and Engineering earned along the way.
        </p>
      </li>
      <li>
        <p class="tl-era">Austin, TX</p>
        <h3>Rippner Tennis</h3>
        <p>
          Branch manager to operations manager to COO in fourteen months. Three facilities, 50
          staff, 363 days a year.
        </p>
      </li>
      <li class="current">
        <p class="tl-era">Today</p>
        <h3>The migration</h3>
        <p>
          Moving all three facilities to a new club management platform, go-live this August.
          Documented in the <a href="/notes">notes</a> as it happens.
        </p>
      </li>
      <li class="future">
        <p class="tl-era">Next</p>
        <h3>What's coming</h3>
        <p>
          <a href="https://playkorta.com">Korta</a>, a tennis matchmaking platform I'm a
          founding member of, launches in Austin. More of the operation automated. All of it
          posted here.
        </p>
      </li>
    </ol>
  </section>

  <section class="section" id="contact">
    <h2 class="label">Contact</h2>
    <p class="contact-line">Happy to connect.</p>
    <p class="muted contact-copy">
      I like meeting people working in sports, AI, or automation, and anyone curious about what
      I'm building. Find me on
      <a href="https://www.linkedin.com/in/gavriella-charalampidi-05456422a/">LinkedIn</a> or
      send a note here:
    </p>
    <form id="contact-form">
      <input type="hidden" name="access_key" value="b16c0877-faf2-4a0b-83b6-aaee2e00087a" />
      <input
        type="checkbox"
        name="botcheck"
        class="botcheck"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
      />
      <div class="form-row">
        <label>
          Name
          <input type="text" name="name" required autocomplete="name" />
        </label>
        <label>
          Email
          <input type="email" name="email" required autocomplete="email" />
        </label>
      </div>
      <label>
        Message
        <textarea name="message" rows="5" required></textarea>
      </label>
      <button type="submit">Send</button>
      <p class="form-status" role="status"></p>
    </form>
  </section>
</Layout>

<script>
  // Scroll effects, all skipped for reduced-motion users:
  // - the hero court sketch lags the page slightly
  // - the timeline baseline draws itself in as you scroll through it
  const court = document.querySelector<SVGElement>('.court');
  const timeline = document.querySelector<HTMLElement>('.timeline');
  const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!reduceMotion && (court || timeline)) {
    const update = () => {
      if (court) court.style.transform = `translateY(${window.scrollY * 0.12}px)`;
      if (timeline) {
        const rect = timeline.getBoundingClientRect();
        const focal = window.innerHeight * 0.7;
        const drawn = Math.min(Math.max(focal - rect.top, 0), rect.height);
        timeline.style.setProperty('--tl-progress', `${drawn}px`);
      }
      ticking = false;
    };
    let ticking = false;
    addEventListener(
      'scroll',
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(update);
      },
      { passive: true }
    );
    update();
  }

  // Timeline entries fade up as they enter the viewport.
  if (timeline && !reduceMotion) {
    const items = [...timeline.querySelectorAll('li')];
    items.forEach((li) => li.classList.add('tl-hidden'));
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.remove('tl-hidden');
            io.unobserve(entry.target);
          }
        });
      },
      { rootMargin: '0px 0px -12% 0px' }
    );
    items.forEach((li) => io.observe(li));
  }

  // Contact form: submits through Web3Forms. Until an access key is set,
  // falls back to opening a prefilled email so the form always works.
  const form = document.querySelector<HTMLFormElement>('#contact-form');
  if (form) {
    const status = form.querySelector<HTMLElement>('.form-status')!;
    const button = form.querySelector<HTMLButtonElement>('button')!;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(form)) as Record<string, string>;
      if (data.botcheck) return;
      if (!data.access_key || data.access_key === 'WEB3FORMS_ACCESS_KEY') {
        status.textContent = 'The form is not connected yet. Message me on LinkedIn instead.';
        return;
      }
      button.disabled = true;
      status.textContent = 'Sending...';
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(data),
        });
        const json = await res.json();
        if (!json.success) throw new Error(json.message);
        form.reset();
        status.textContent = 'Got it. I read everything that comes in here.';
      } catch {
        status.textContent = 'That did not go through. Reach me on LinkedIn instead.';
      }
      button.disabled = false;
    });
  }
</script>

<style>
  .hero {
    position: relative;
    margin-top: 3.5rem;
  }

  .court {
    position: absolute;
    top: -1.5rem;
    right: -2.5rem;
    width: 175px;
    color: var(--line);
    z-index: -1;
  }

  .hero h1 {
    font-size: clamp(2.2rem, 6.5vw, 3.4rem);
    max-width: 20ch;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--accent);
  }

  .lede {
    margin-top: 1.3rem;
    font-size: 1.1rem;
    color: var(--muted);
    max-width: 32rem;
  }

  .kicker {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.25rem;
    color: var(--ink);
    max-width: 30rem;
    margin: 0 0 2rem;
  }

  .projects {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }

  .projects li {
    background: var(--bg);
    padding: 1rem 1.1rem 1.1rem;
    transition: background 140ms ease;
  }

  .projects li:hover {
    background: #1c1f26;
  }

  .num {
    font-size: 0.68rem;
    letter-spacing: 0.09em;
    color: var(--accent);
  }

  .projects h3 {
    font-size: 1.02rem;
    margin: 0.35rem 0 0.3rem;
  }

  .projects p {
    margin: 0;
    font-size: 0.83rem;
    color: var(--muted);
  }

  .stack {
    display: block;
    margin-top: 0.7rem;
    font-size: 0.66rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--faint);
  }

  .timeline {
    list-style: none;
    padding: 0 0 0 1.8rem;
    margin: 0;
    position: relative;
  }

  /* the vertical baseline */
  .timeline::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.4rem;
    bottom: 0.4rem;
    width: 1px;
    background: var(--line);
  }

  /* the drawn-in portion of the baseline, height driven by scroll */
  .timeline::after {
    content: '';
    position: absolute;
    left: 0;
    top: 0.4rem;
    width: 1px;
    height: var(--tl-progress, 0px);
    max-height: calc(100% - 0.8rem);
    background: var(--accent);
  }

  .timeline li {
    position: relative;
    padding-bottom: 2.2rem;
    transition: opacity 600ms ease, transform 600ms ease;
  }

  .timeline li.tl-hidden {
    opacity: 0;
    transform: translateY(14px);
  }

  .timeline li:last-child {
    padding-bottom: 0;
  }

  /* tick node crossing the baseline, same mark as the section dividers */
  .timeline li::before {
    content: '';
    position: absolute;
    left: -1.8rem;
    top: 0.5rem;
    width: 11px;
    height: 1px;
    background: var(--ink);
    transform: translateX(-5px);
  }

  .tl-era {
    margin: 0 0 0.3rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--faint);
  }

  .timeline h3 {
    font-size: 1.25rem;
    margin: 0 0 0.4rem;
  }

  .timeline p:not(.tl-era) {
    margin: 0;
    color: var(--muted);
    max-width: 32rem;
  }

  .timeline li.current::before {
    background: var(--accent);
    height: 3px;
    top: 0.45rem;
  }

  .timeline li.current .tl-era {
    color: var(--accent);
  }

  .timeline li.future::before {
    background: var(--faint);
  }

  .timeline li.future h3,
  .timeline li.future p:not(.tl-era) {
    opacity: 0.75;
  }

  .note-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .note-list li {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.7rem 0;
  }

  .note-list li + li {
    border-top: 1px solid var(--line);
  }

  .note-list a {
    text-decoration: none;
    font-weight: 500;
  }

  .note-meta {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    font-size: 0.85rem;
    color: var(--faint);
    white-space: nowrap;
  }

  .tag {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.1rem 0.55rem;
  }

  .all-notes {
    margin-top: 1rem;
    font-size: 0.92rem;
  }

  .contact-line {
    font-family: var(--serif);
    font-size: clamp(1.5rem, 4vw, 2rem);
    margin: 0 0 0.8rem;
  }

  .contact-copy {
    max-width: 34rem;
  }

  #contact-form {
    margin-top: 1.8rem;
    max-width: 34rem;
  }

  .botcheck {
    display: none;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  #contact-form label {
    display: block;
    margin-bottom: 1rem;
    font-size: 0.78rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--muted);
  }

  #contact-form input[type='text'],
  #contact-form input[type='email'],
  #contact-form textarea {
    display: block;
    width: 100%;
    margin-top: 0.4rem;
    padding: 0.65rem 0.8rem;
    background: #21242c;
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--ink);
    font-family: var(--sans);
    font-size: 0.98rem;
    letter-spacing: normal;
    text-transform: none;
    box-sizing: border-box;
    resize: vertical;
  }

  #contact-form input:focus,
  #contact-form textarea:focus {
    outline: none;
    border-color: var(--accent);
  }

  #contact-form button {
    margin-top: 0.2rem;
    padding: 0.65rem 1.6rem;
    background: var(--accent);
    color: var(--bg);
    border: 0;
    border-radius: 8px;
    font-family: var(--sans);
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 120ms ease;
  }

  #contact-form button:hover {
    opacity: 0.85;
  }

  #contact-form button:disabled {
    opacity: 0.5;
    cursor: default;
  }

  .form-status {
    margin: 0.9rem 0 0;
    font-size: 0.92rem;
    color: var(--muted);
    min-height: 1.4em;
  }

  @media (max-width: 560px) {
    .form-row {
      grid-template-columns: 1fr;
      gap: 0;
    }
  }

  @media (max-width: 560px) {
    .court {
      display: none;
    }

    .projects {
      grid-template-columns: 1fr;
    }
  }
</style>
