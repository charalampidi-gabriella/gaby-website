---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';

const notes = (await getCollection('notes', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const latest = notes.slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric', timeZone: 'UTC' });

const projects = [
  {
    name: 'Attendance escalation engine',
    stack: 'Apps Script',
    what: 'Encodes the attendance policy: log a call-out and it counts that coach’s rolling history, picks the escalation step, and emails management the exact next action.',
  },
  {
    name: 'Inventory system',
    stack: 'Express · LibSQL',
    what: 'Stock counts, transfers, and low-stock alerts across three tennis centers.',
  },
  {
    name: 'Compliance tracker',
    stack: 'Sheets · Apps Script',
    what: '50 staff, five certifications, zero manual entry. A weekly digest emails whoever is about to lapse.',
  },
  {
    name: 'Club software extensions',
    stack: 'Chrome · Apps Script',
    what: 'Two Chrome extensions that patch what our club platform is missing: payroll recalculation across all locations and live coach notes on the court sheets.',
  },
  {
    name: 'rippnertennis.com',
    stack: 'Next.js · Cloudflare',
    what: 'The three-facility marketing site, rebuilt from WordPress. 33 routes, a gated admin dashboard, a live racket inventory browser.',
  },
  {
    name: 'Internal tools portal',
    stack: 'Cloudflare Pages',
    what: 'One home for the operation’s single-purpose tools: coach scheduling, staffing dashboards built on the Connecteam API, and whatever the next problem needs.',
  },
];
---

<Layout title="Gaby Charalampidi" current="home">
  <section class="hero">
    <svg class="court" viewBox="0 0 260 240" aria-hidden="true" fill="none">
      <rect x="30" y="10" width="200" height="220" stroke="currentColor" />
      <line x1="30" y1="65" x2="230" y2="65" stroke="currentColor" />
      <line x1="30" y1="175" x2="230" y2="175" stroke="currentColor" />
      <line x1="130" y1="65" x2="130" y2="175" stroke="currentColor" />
      <line x1="8" y1="120" x2="252" y2="120" stroke="currentColor" stroke-width="2" />
    </svg>
    <p class="eyebrow">Austin, TX</p>
    <h1>
      I <em>run</em> tennis facilities and <em>build</em> the software that runs them.
    </h1>
    <p class="lede">
      COO at <a href="https://rippnertennis.com">Rippner Tennis</a>. When the operation needs a
      tool that does not exist, I build it myself.
    </p>
  </section>

  <section class="section" id="now">
    <h2 class="label">Now</h2>
    <ul class="now-list">
      <li>
        <span class="now-title">Platform migration.</span> Moving all three facilities to a new
        club management system, go-live this August. Setup, data, pricing, automation, training:
        all mine.
      </li>
      <li>
        <span class="now-title">Building in public.</span> Writing and recording
        <a href="/notes">notes</a> on operations and the software behind them.
      </li>
      <li>
        <span class="now-title">Korta.</span> A founding member of
        <a href="https://playkorta.com">Korta</a>, a tennis matchmaking platform launching in
        Austin.
      </li>
    </ul>
  </section>

  <section class="section" id="work">
    <h2 class="label">Things I've built</h2>
    <p class="kicker">
      Every tool here exists because something broke, cost hours, or lived in one person's head.
    </p>
    <ol class="projects">
      {
        projects.map((p, i) => (
          <li>
            <span class="num">{String(i + 1).padStart(2, '0')}</span>
            <h3>{p.name}</h3>
            <p>{p.what}</p>
            <span class="stack">{p.stack}</span>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="section" id="about">
    <h2 class="label">Before this</h2>
    <p class="bio">
      ITF juniors, the Greek National Team, then Division I tennis at Nevada on a full athletic
      scholarship, with a computer science and engineering degree earned along the way. This job
      is the overlap of the two things I know best.
    </p>
  </section>

  {
    latest.length > 0 && (
      <section class="section" id="notes">
        <h2 class="label">Latest notes</h2>
        <ul class="note-list">
          {latest.map((note) => (
            <li>
              <a href={`/notes/${note.id}`}>{note.data.title}</a>
              <span class="note-meta">
                {note.data.type === 'video' && <span class="tag">Video</span>}
                <time datetime={note.data.date.toISOString()}>{fmt(note.data.date)}</time>
              </span>
            </li>
          ))}
        </ul>
        <p class="all-notes">
          <a href="/notes">All notes &rarr;</a>
        </p>
      </section>
    )
  }

  <section class="section" id="contact">
    <h2 class="label">Contact</h2>
    <p class="contact-line">Happy to connect.</p>
    <p class="muted contact-copy">
      I like meeting people working in sports, AI, or automation, and anyone curious about what
      I'm building. Find me on
      <a href="https://www.linkedin.com/in/gavriella-charalampidi-05456422a/">LinkedIn</a> or
      send a note here:
    </p>
    <form id="contact-form">
      <input type="hidden" name="access_key" value="b16c0877-faf2-4a0b-83b6-aaee2e00087a" />
      <input
        type="checkbox"
        name="botcheck"
        class="botcheck"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
      />
      <div class="form-row">
        <label>
          Name
          <input type="text" name="name" required autocomplete="name" />
        </label>
        <label>
          Email
          <input type="email" name="email" required autocomplete="email" />
        </label>
      </div>
      <label>
        Message
        <textarea name="message" rows="5" required></textarea>
      </label>
      <button type="submit">Send</button>
      <p class="form-status" role="status"></p>
    </form>
  </section>
</Layout>

<script>
  // The hero court sketch lags the page slightly on scroll. Kept faint on purpose.
  const court = document.querySelector<SVGElement>('.court');
  const reduceMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (court && !reduceMotion) {
    let ticking = false;
    addEventListener(
      'scroll',
      () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          court.style.transform = `translateY(${window.scrollY * 0.12}px)`;
          ticking = false;
        });
      },
      { passive: true }
    );
  }

  // Contact form: submits through Web3Forms. Until an access key is set,
  // falls back to opening a prefilled email so the form always works.
  const form = document.querySelector<HTMLFormElement>('#contact-form');
  if (form) {
    const status = form.querySelector<HTMLElement>('.form-status')!;
    const button = form.querySelector<HTMLButtonElement>('button')!;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const data = Object.fromEntries(new FormData(form)) as Record<string, string>;
      if (data.botcheck) return;
      if (!data.access_key || data.access_key === 'WEB3FORMS_ACCESS_KEY') {
        status.textContent = 'The form is not connected yet. Message me on LinkedIn instead.';
        return;
      }
      button.disabled = true;
      status.textContent = 'Sending...';
      try {
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify(data),
        });
        const json = await res.json();
        if (!json.success) throw new Error(json.message);
        form.reset();
        status.textContent = 'Got it. I read everything that comes in here.';
      } catch {
        status.textContent = 'That did not go through. Reach me on LinkedIn instead.';
      }
      button.disabled = false;
    });
  }
</script>

<style>
  .hero {
    position: relative;
    margin-top: 3.5rem;
  }

  .court {
    position: absolute;
    top: -1.5rem;
    right: -3rem;
    width: 230px;
    color: var(--line);
    z-index: -1;
  }

  .hero h1 {
    font-size: clamp(2.2rem, 6.5vw, 3.4rem);
    max-width: 20ch;
  }

  .hero h1 em {
    font-style: italic;
    color: var(--accent);
  }

  .lede {
    margin-top: 1.3rem;
    font-size: 1.1rem;
    color: var(--muted);
    max-width: 32rem;
  }

  .now-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .now-list li {
    padding: 0.85rem 0;
    color: var(--muted);
  }

  .now-list li + li {
    border-top: 1px solid var(--line);
  }

  .now-title {
    color: var(--ink);
    font-weight: 500;
  }

  .kicker {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.25rem;
    color: var(--ink);
    max-width: 30rem;
    margin: 0 0 2rem;
  }

  .projects {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--line);
    border: 1px solid var(--line);
  }

  .projects li {
    background: var(--bg);
    padding: 1.3rem 1.4rem 1.5rem;
    transition: background 140ms ease;
  }

  .projects li:hover {
    background: #1c1f26;
  }

  .num {
    font-size: 0.72rem;
    letter-spacing: 0.09em;
    color: var(--accent);
  }

  .projects h3 {
    font-size: 1.25rem;
    margin: 0.4rem 0 0.45rem;
  }

  .projects p {
    margin: 0;
    font-size: 0.93rem;
    color: var(--muted);
  }

  .stack {
    display: block;
    margin-top: 0.9rem;
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--faint);
  }

  .bio {
    font-size: 1.05rem;
    max-width: 36rem;
    margin: 0;
  }

  .note-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .note-list li {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.7rem 0;
  }

  .note-list li + li {
    border-top: 1px solid var(--line);
  }

  .note-list a {
    text-decoration: none;
    font-weight: 500;
  }

  .note-meta {
    display: flex;
    align-items: baseline;
    gap: 0.7rem;
    font-size: 0.85rem;
    color: var(--faint);
    white-space: nowrap;
  }

  .tag {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.1rem 0.55rem;
  }

  .all-notes {
    margin-top: 1rem;
    font-size: 0.92rem;
  }

  .contact-line {
    font-family: var(--serif);
    font-size: clamp(1.5rem, 4vw, 2rem);
    margin: 0 0 0.8rem;
  }

  .contact-copy {
    max-width: 34rem;
  }

  #contact-form {
    margin-top: 1.8rem;
    max-width: 34rem;
  }

  .botcheck {
    display: none;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  #contact-form label {
    display: block;
    margin-bottom: 1rem;
    font-size: 0.78rem;
    letter-spacing: 0.09em;
    text-transform: uppercase;
    color: var(--muted);
  }

  #contact-form input[type='text'],
  #contact-form input[type='email'],
  #contact-form textarea {
    display: block;
    width: 100%;
    margin-top: 0.4rem;
    padding: 0.65rem 0.8rem;
    background: #21242c;
    border: 1px solid var(--line);
    border-radius: 8px;
    color: var(--ink);
    font-family: var(--sans);
    font-size: 0.98rem;
    letter-spacing: normal;
    text-transform: none;
    box-sizing: border-box;
    resize: vertical;
  }

  #contact-form input:focus,
  #contact-form textarea:focus {
    outline: none;
    border-color: var(--accent);
  }

  #contact-form button {
    margin-top: 0.2rem;
    padding: 0.65rem 1.6rem;
    background: var(--accent);
    color: var(--bg);
    border: 0;
    border-radius: 8px;
    font-family: var(--sans);
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 120ms ease;
  }

  #contact-form button:hover {
    opacity: 0.85;
  }

  #contact-form button:disabled {
    opacity: 0.5;
    cursor: default;
  }

  .form-status {
    margin: 0.9rem 0 0;
    font-size: 0.92rem;
    color: var(--muted);
    min-height: 1.4em;
  }

  @media (max-width: 560px) {
    .form-row {
      grid-template-columns: 1fr;
      gap: 0;
    }
  }

  @media (max-width: 560px) {
    .court {
      display: none;
    }

    .projects {
      grid-template-columns: 1fr;
    }
  }
</style>
