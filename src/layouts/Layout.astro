---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  current?: 'home' | 'notes';
  ogImage?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description = 'Gaby Charalampidi runs Rippner Tennis in Austin and builds the software behind it.',
  current,
  ogImage = '/og-default.png',
  ogType = 'website',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImageAbs = ogImage.startsWith('http') ? ogImage : new URL(ogImage, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#17191e" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="Gaby Charalampidi" />
    <meta property="og:image" content={ogImageAbs} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-BH9KVZ9R10"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-BH9KVZ9R10');
    </script>
  </head>
  <body>
    <header class="site-header">
      <a class="wordmark" href="/">Gaby Charalampidi</a>
      <nav>
        <a href="/" aria-current={current === 'home' ? 'page' : undefined}>Home</a>
        <a href="/notes" aria-current={current === 'notes' ? 'page' : undefined}>Notes</a>
        <a href="/#contact">Contact</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      &copy; {new Date().getFullYear()} Gaby Charalampidi &middot; Austin, TX
    </footer>
    <script>
      // External links open in a new tab; internal navigation stays put.
      document.querySelectorAll<HTMLAnchorElement>('a[href^="http"]').forEach((a) => {
        if (a.hostname !== location.hostname) {
          a.target = '_blank';
          a.rel = 'noopener';
        }
      });
    </script>
  </body>
</html>
